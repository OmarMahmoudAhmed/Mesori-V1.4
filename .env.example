# انسخ هذا الملف باسم .env واملأ القيم من Supabase Dashboard → Settings → API
# لا ترفع .env على GitHub أبداً (موجود بالفعل في .gitignore)

# يُستخدم في الواجهة (src/lib/supabaseClient.js) وفي سكريبت الرفع (scripts/seed.js)
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# آمن للاستخدام في الواجهة الأمامية (client-side) — هذا هو الغرض منه
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ⚠️ سرّي جداً — يُستخدم فقط في scripts/seed.js (بيئة Node، ليس في المتصفح أبداً)
# لا تضِف VITE_ في بدايته، وإلا سيُضمَّن في حزمة الواجهة الأمامية العامة
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
